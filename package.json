{
  "name": "familyshield-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm test",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:setup": "node scripts/apply-dev-schema.mjs",
    "db:prod:setup": "node scripts/apply-production-schema.mjs",
    "db:check": "node scripts/check-production-schema.mjs"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@neondatabase/serverless": "^0.10.0",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.36.0",
    "firebase-admin": "^13.0.0",
    "jose": "^5.9.0",
    "maplibre-gl": "^4.7.1",
    "next": "^16.0.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swagger-ui-dist": "^5.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
